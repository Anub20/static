<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Static Balancing Simulator</title>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@300;400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="style.css">
</head>
<body>
<div class="shell">
  <header>
    <div class="title-block">
      <h1>Static Balancing</h1>
      <span class="tag" id="balance-tag">Balanced</span>
    </div>
    <div class="rpm-display">ω = <span id="rpm-val">1000</span> rpm &nbsp;|&nbsp; <span id="omega-val">104.7</span> rad/s</div>
  </header>

  <div class="main-grid">

    <div class="canvas-panel">
      <div class="panel-bar">
        <span class="panel-label">Rotor disc — plan view</span>
        <div class="panel-actions">
          <button id="btn-static" class="active" onclick="showView('static')">Static</button>
          <button id="btn-spin" onclick="showView('spin')">Animate</button>
        </div>
      </div>
      <canvas id="rotor"></canvas>
      <canvas id="spin-canvas"></canvas>
      <div class="status-bar">
        <div class="status-dot" id="sdot"></div>
        <span id="stxt">—</span>
      </div>
    </div>

    <div class="side">

      <div class="card">
        <div class="card-head"><div class="dot dot-red"></div><span class="card-title">Mass 1</span></div>
        <div class="card-body">
          <div class="ctrl-row">
            <span class="ctrl-label">Mass</span>
            <input type="range" id="m1" class="red-track" min="0" max="300" value="80" step="1">
            <span class="ctrl-val" id="m1v">80 g</span>
          </div>
          <div class="ctrl-row">
            <span class="ctrl-label">Radius</span>
            <input type="range" id="r1" class="red-track" min="10" max="100" value="60" step="1">
            <span class="ctrl-val" id="r1v">60</span>
          </div>
          <div class="ctrl-row">
            <span class="ctrl-label">Angle</span>
            <input type="range" id="a1" class="red-track" min="0" max="359" value="45" step="1">
            <span class="ctrl-val" id="a1v">45°</span>
          </div>
        </div>
      </div>

      <div class="card">
        <div class="card-head"><div class="dot dot-blue"></div><span class="card-title">Mass 2</span></div>
        <div class="card-body">
          <div class="ctrl-row">
            <span class="ctrl-label">Mass</span>
            <input type="range" id="m2" class="blue-track" min="0" max="300" value="60" step="1">
            <span class="ctrl-val" id="m2v">60 g</span>
          </div>
          <div class="ctrl-row">
            <span class="ctrl-label">Radius</span>
            <input type="range" id="r2" class="blue-track" min="10" max="100" value="50" step="1">
            <span class="ctrl-val" id="r2v">50</span>
          </div>
          <div class="ctrl-row">
            <span class="ctrl-label">Angle</span>
            <input type="range" id="a2" class="blue-track" min="0" max="359" value="200" step="1">
            <span class="ctrl-val" id="a2v">200°</span>
          </div>
        </div>
      </div>

      <div class="card">
        <div class="card-head"><div class="dot dot-gray"></div><span class="card-title">Speed</span></div>
        <div class="card-body">
          <div class="ctrl-row">
            <span class="ctrl-label">RPM</span>
            <input type="range" id="rpm" class="gray-track" min="100" max="5000" value="1000" step="50">
            <span class="ctrl-val" id="rpmv">1000</span>
          </div>
        </div>
      </div>

      <div class="metrics-grid">
        <div class="metric"><div class="mlabel">Resultant F</div><div class="mval" id="mF">0.0</div><div class="munit">Newtons</div></div>
        <div class="metric"><div class="mlabel">Angle</div><div class="mval" id="mA">—</div><div class="munit">degrees</div></div>
        <div class="metric"><div class="mlabel">Corr. mass</div><div class="mval" id="mC">0.0</div><div class="munit">g @ r=60mm</div></div>
        <div class="metric"><div class="mlabel">mr product</div><div class="mval" id="mMR">0</div><div class="munit">g·mm</div></div>
      </div>

      <div class="card">
        <div class="card-head"><div class="dot dot-green"></div><span class="card-title">Vector diagram</span></div>
        <div class="card-body" style="display:flex;gap:1rem;align-items:center;">
          <canvas id="vec" width="140" height="140"></canvas>
          <div style="font-family:var(--font-mono);font-size:0.65rem;color:var(--muted);line-height:2;">
            <div><span style="color:var(--red)">●</span> m₁r₁ vector</div>
            <div><span style="color:var(--blue)">●</span> m₂r₂ vector</div>
            <div><span style="color:var(--green)">●</span> Resultant</div>
            <div><span style="color:var(--gray)">◌</span> Correction</div>
          </div>
        </div>
      </div>

    </div>
  </div>

  <div class="formula-strip">
    <div class="formula">
      <div class="f-label">Centrifugal force</div>
      <div class="f-expr">F = <em>m · r · ω²</em></div>
    </div>
    <div class="formula">
      <div class="f-label">Balance condition</div>
      <div class="f-expr">Σ <em>mᵢ · rᵢ</em> = <em>0</em></div>
    </div>
    <div class="formula">
      <div class="f-label">Angular velocity</div>
      <div class="f-expr">ω = <em>2π · N / 60</em></div>
    </div>
    <div class="formula">
      <div class="f-label">Correction mass</div>
      <div class="f-expr">mc = <em>|Σmr| / rc</em></div>
    </div>
  </div>
</div>
<script src="script.js"></script>
</body>
</html>
